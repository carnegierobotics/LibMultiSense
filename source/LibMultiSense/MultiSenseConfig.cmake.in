@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(MultiSenseWire)
if (@BUILD_JSON_SERIALIZATION@)
    find_dependency(nlohmann_json 3.9)
endif ()
if (@BUILD_OPENCV@)
    find_dependency(OpenCV REQUIRED COMPONENTS core features2d imgcodecs)
endif ()
find_dependency(Threads)

include("${CMAKE_CURRENT_LIST_DIR}/MultiSenseCxxCheckConstexpr.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/MultiSenseCxxCheckFilesystem.cmake")

set(MULTISENSE_COMPILER_CHECKS_VIOLATED FALSE)
if (NOT HAVE_CONSTEXPR)
    message(SEND_ERROR "Failed C++ constexpr check")
    set(MULTISENSE_COMPILER_CHECKS_VIOLATED TRUE)
endif()
if (NOT HAVE_STD_FILESYSTEM)
    message(SEND_ERROR "Failed C++ filesystem check")
    set(MULTISENSE_COMPILER_CHECKS_VIOLATED TRUE)
endif()

if (MULTISENSE_COMPILER_CHECKS_VIOLATED)
    message(FATAL_ERROR "The new MultiSense API requires at minimum a C++17 standard")
endif()

include("${CMAKE_CURRENT_LIST_DIR}/MultiSenseTargets.cmake")

check_required_components(MultiSense)
